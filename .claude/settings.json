{
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/session-startup.sh",
            "timeout": 10,
            "statusMessage": "Running session startup checks..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/validate-security-edit.sh",
            "timeout": 10,
            "statusMessage": "Security validation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/auto-test.sh",
            "timeout": 120,
            "statusMessage": "Running related tests..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/pre-compact-handoff.sh",
            "timeout": 5,
            "statusMessage": "Preserving session context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if Python code was modified in this session. If Python files were edited but no test results appear in the conversation, return {\"decision\": \"block\", \"reason\": \"Tests not run after code changes — run pytest before stopping\"}. Otherwise return {\"decision\": \"approve\"}."
          }
        ]
      }
    ]
  }
}
